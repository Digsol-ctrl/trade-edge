// Prisma schema for trade journal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// enums

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  trades    Trade[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trade {
  id              String         @id @default(uuid())
  user            User           @relation(fields: [userId], references: [id])
  userId          String
  pair            String
  direction       TradeDirection
  entryPrice      Float
  exitPrice       Float?
  stopLoss        Float?
  takeProfit      Float?
  positionSize    Float?
  riskPercent     Float?
  pnl             Float?
  rMultiple       Float?
  strategy        String?
  timeframe       String?
  session         String?
  marketCondition String?
  confidence      Int?           // 1-10
  mistakes        String?
  notes           String?
  screenshots     String[]
  status          TradeStatus    @default(OPEN)
  openedAt        DateTime
  closedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
